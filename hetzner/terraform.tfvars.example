hcloud_token = "replace-me"

cluster_name = "idklol-k3s"
location     = "fsn1"
server_type  = "cx33"
image        = "ubuntu-24.04"

# Paste your public SSH key contents here.
ssh_public_key       = "ssh-ed25519 AAAA... your@machine"
ssh_private_key_path = "~/.ssh/id_ed25519"

# Set to false if this key name already exists in your Hetzner project.
create_ssh_key = true

# Restrict these in production.
ssh_allowed_cidrs            = ["0.0.0.0/0", "::/0"]
kube_api_allowed_cidrs       = ["0.0.0.0/0", "::/0"]
public_ingress_allowed_cidrs = ["0.0.0.0/0", "::/0"]

# Leave empty for latest stable k3s.
k3s_version = ""

# Generated kubeconfig for app-stack Terraform root.
local_kubeconfig_path = "./generated/kubeconfig.yaml"