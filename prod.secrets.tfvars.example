# Production secrets for Terraform.
# Copy to `prod.secrets.tfvars` (ignored by git) for local runs.
# For CI, base64-encode this file and store it as GitHub secret `PROD_TFVARS_B64`.

external_postgres_username = "replace-me"
external_postgres_password = "replace-me"

keycloak_admin_username         = "replace-me"
keycloak_admin_password         = "replace-me"
keycloak_chat_client_secret     = "replace-me"
keycloak_webadmin_client_secret = "replace-me"
nextauth_secret                 = "replace-me"

# Optional secret values
otlp_auth_header = null
